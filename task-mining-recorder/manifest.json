{
  "manifest_version": 3,
  "name": "Celonis Task Mining — Recorder (demo)",
  "version": "0.3.0",
  "description": "Local demo: record real browser activity, mask PII on-device, detect case IDs, and stream it live for data-quality & privacy validation.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Task Mining Recorder"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scan-lib.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
