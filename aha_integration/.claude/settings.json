{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/f.chettouh/Desktop/AhaAgent && python scripts/check_env.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in *.py) python -m py_compile \"$CLAUDE_FILE_PATH\" 2>&1 || exit 2 ;; esac"
          }
        ]
      }
    ]
  }
}
