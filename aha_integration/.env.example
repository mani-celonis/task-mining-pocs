AHA_API_KEY=

# PM knowledge root (Obsidian vault or folder). Most files use $KNOWLEDGE_ROOT/AhaAgent/... (glossary, meetings,
# intake, jira-briefs) plus Tasks/ and GOALS.md at vault root. Dated feature-suggestion API exports (aha_feature_suggestions)
# go to $KNOWLEDGE_ROOT/incoming/feature-suggestions/ when set. See docs/knowledge_layout.md.
# Example (adjust to your machine):
# KNOWLEDGE_ROOT=/Users/f.chettouh/Desktop/personal-context-portfolio/portfolio
# KNOWLEDGE_ROOT=

# Jira Cloud (read-only: src/executors/jira_board_overview.py)
JIRA_HOST=https://celonis.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# Preferred for PM / ML Infra slice (~hundreds of issues, not full board history).
# Use single-quoted value so '=' inside JQL is preserved.
JIRA_JQL='project = TM AND issuetype NOT IN (Epic, Sub-task) AND statusCategory != Done AND (sprint IN openSprints() OR sprint IS EMPTY) AND component = "ML Infra" ORDER BY Rank ASC'

# Optional: multiline JQL file under repo (e.g. data/jira-jql/ml-infra.jql — gitignored).
# Ignored when JIRA_JQL is set.
# JIRA_JQL_PATH=data/jira-jql/ml-infra.jql

# Fallback when JIRA_JQL and JIRA_JQL_PATH are unset: full Agile board (can be 1000s of issues).
# JIRA_BOARD_ID=435

# Include description (ADF) + sprint in JSON for detailed PM briefs (larger payloads).
# JIRA_EXTRA_FIELDS=true
